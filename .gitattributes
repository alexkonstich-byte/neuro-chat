# Force LF line endings for shell scripts and conf files used on Linux.
*.sh        text eol=lf
*.conf      text eol=lf
*.cjs       text eol=lf
.env*       text eol=lf

# Source code: normalise to LF on commit.
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.md        text eol=lf
*.html      text eol=lf

# Binaries — never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.svg       text eol=lf
*.ico       binary
*.woff      binary
*.woff2     binary
